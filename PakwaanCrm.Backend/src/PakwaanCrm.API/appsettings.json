{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=PakwaanCrmDb;Username=postgres;Password=SET_IN_ENV_OR_APPSETTINGS"
  },
  "CorsSettings": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Issuer": "PakwaanCrm",
    "Audience": "PakwaanCrmClient",
    "SigningKey": "CHANGE_THIS_IN_ENV_TO_A_LONG_RANDOM_SECRET_32+",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Swagger": {
    "Enabled": true
  }
}
